# ============================================================
# Hyperliquid Maker Bot - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- Exchange ---
# FACT: Hyperliquid uses Ethereum private key for signing
PRIVATE_KEY=0xyour_private_key_here
WALLET_ADDRESS=0xyour_wallet_address_here

# FACT: Testnet and mainnet are separate environments
TESTNET=true

# --- Trading ---
# Comma-separated list of symbols to trade (Perp only in v1)
SYMBOLS=BTC,ETH

# ASSUMPTION: leverage=1 for isolated, safe starting point
LEVERAGE=1

# --- Position / Order Size Limits (USD) ---
# Safe starting values for small-scale verification
MAX_ORDER_SIZE_USD=25
MAX_POSITION_USD_PER_SYMBOL=50
MAX_TOTAL_EXPOSURE_USD=100

# --- Loss Limits ---
MAX_DAILY_LOSS_PCT=2.0
MAX_INTRADAY_DRAWDOWN_PCT=1.0

# --- Quote Engine ---
BASE_SPREAD_BPS=10
MIN_EDGE_BPS=5
VOL_MULTIPLIER=2.0
INVENTORY_SKEW_MAX_BPS=20
IMBALANCE_WEIGHT=0.5

# Quote refresh and age (milliseconds)
QUOTE_REFRESH_MS=5000
MAX_QUOTE_AGE_MS=30000
# Minimum price move (in bps) before replacing a quote
PRICE_REPLACE_THRESHOLD_BPS=2.0

# --- Risk / Safety ---
STALE_DATA_THRESHOLD_MS=5000
ABNORMAL_SPREAD_MULTIPLIER=5.0
ABRUPT_MOVE_PCT=1.0
MAX_REJECT_STREAK=10
MAX_RECONNECT_STREAK=5
RECONNECT_WINDOW_S=60

EMERGENCY_FLATTEN_ENABLED=true

# --- Dashboard ---
DASHBOARD_ENABLED=true
# WARNING: Changing host to 0.0.0.0 exposes the dashboard externally.
# Only do this on a trusted network. See README for security notes.
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8080

# --- Logging ---
LOG_LEVEL=INFO
LOG_DIR=logs
DB_PATH=data/bot.db
